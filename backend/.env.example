# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais committer backend/.env — il contient des secrets.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=REMPLACE_PAR_UNE_CHAINE_ALEATOIRE_32_CHARS
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://stockshop:password@database:3306/stockshop_db?serverVersion=8.0"
###< doctrine/doctrine-bundle ###

###> stripe/stripe-php ###
# Clé secrète Stripe — récupérer sur https://dashboard.stripe.com/test/apikeys
# Ne jamais exposer cette clé côté client
STRIPE_SECRET_KEY=sk_test_REMPLACE_PAR_TA_CLE
# Clé publiable Stripe — peut être utilisée côté frontend
STRIPE_PUBLISHABLE_KEY=pk_test_REMPLACE_PAR_TA_CLE
###< stripe/stripe-php ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###
